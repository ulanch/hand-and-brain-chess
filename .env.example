# Root-level .env.example — see package-level files for full details.
#
# packages/client/.env.example  — VITE_SERVER_URL
# packages/server/.env.example  — PORT, CLIENT_ORIGIN
#
# Copy the relevant package-level file to .env inside that package before
# running locally, e.g.:
#
#   cp packages/client/.env.example packages/client/.env
#   cp packages/server/.env.example packages/server/.env
